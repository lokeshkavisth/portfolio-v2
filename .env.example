# Resend API key — get one at https://resend.com
RESEND_API_KEY=re_xxxxxxxx

# Where contact form submissions are delivered
CONTACT_EMAIL=lokeshkavisth.dev@gmail.com

# Sender address (use onboarding@resend.dev until your domain is verified in Resend)
RESEND_FROM=Portfolio Contact <onboarding@resend.dev>

# Optional: WhatsApp number with country code, no + sign (e.g. 919876543210)
NEXT_PUBLIC_WHATSAPP_NUMBER=

# Optional: Calendly link for "Book a call" button after form submit
NEXT_PUBLIC_CALENDLY_URL=

# Add the same variables in Vercel → Project → Settings → Environment Variables for production.
